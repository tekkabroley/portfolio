---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';

const galleryEntries = await getCollection('gallery');
const images = import.meta.glob('/src/content/gallery/*.{jpg,jpeg,png,webp}');

// Helper to get the imported image object for a given entry
const getImageAsset = (entry) => {
  const path = `/src/content/gallery/${entry.data.image.replace('./', '')}`;
  return images[path];
};
---

<Layout title="Photography Portfolio">
  <div class="flex flex-col gap-0">
    <!-- Hero Section: Full-bleed impactful image -->
    <section class="relative h-[90vh] w-full overflow-hidden bg-neutral-900">
      {galleryEntries[0] && getImageAsset(galleryEntries[0]) ? (
        <Image
          src={getImageAsset(galleryEntries[0])()}
          alt={galleryEntries[0].data.title || 'Photography work by Alex B.'}
          class="h-full w-full object-cover opacity-80 transition-transform duration-700 hover:scale-105"
        />
      ) : (
        <div class="h-full w-full bg-neutral-800" />
      )}
      <div class="absolute inset-0 flex flex-col justify-end p-6 md:p-12 lg:p-20 bg-gradient-to-t from-black/60 to-transparent">
        <h1 class="text-6xl md:text-8xl font-bold tracking-tighter text-white mb-4">ALEX B.</h1>
        <p class="text-lg md:text-2xl text-gray-200 max-w-xl font-light">
          Capturing the stark contrast of urban environments and architectural forms.
        </p>
      </div>
    </section>

    <!-- Fluid Gallery Grid -->
    <section class="p-4 md:p-8 lg:p-12">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4 auto-rows-[300px]">

        {/* Large featured image - use 2nd image */}
        <div class="md:col-span-2 md:row-span-2 relative group overflow-hidden bg-neutral-800">
          {galleryEntries[1] && getImageAsset(galleryEntries[1]) && (
            <>
              <Image
                src={getImageAsset(galleryEntries[1])()}
                alt={galleryEntries[1].data.title || 'Photography work by Alex B.'}
                class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
              />
              <div class="absolute inset-0 bg-black/20 opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-center justify-center">
                <span class="text-white text-sm font-medium tracking-widest uppercase">{galleryEntries[1].data.title}</span>
              </div>
            </>
          )}
        </div>

        {/* Small images - use 3rd and 4th */}
        {[2, 3].map((index) => (
          <div class="relative group overflow-hidden bg-neutral-800">
            {galleryEntries[index] && getImageAsset(galleryEntries[index]) && (
              <>
                <Image
                  src={getImageAsset(galleryEntries[index])()}
                  alt={galleryEntries[index].data.title || 'Photography work by Alex B.'}
                  class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
                />
                <div class="absolute inset-0 bg-black/20 opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-center justify-center">
                  <span class="text-white text-sm font-medium tracking-widest uppercase">{galleryEntries[index].data.title}</span>
                </div>
              </>
            )}
          </div>
        ))}

        {/* Bottom row images - use 5th and 6th */}
        <div class="md:col-span-1 relative group overflow-hidden bg-neutral-800">
          {galleryEntries[4] && getImageAsset(galleryEntries[4]) && (
            <>
              <Image
                src={getImageAsset(galleryEntries[4])()}
                alt={galleryEntries[4].data.title || 'Photography work by Alex B.'}
                class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
              />
              <div class="absolute inset-0 bg-black/20 opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-center justify-center">
                <span class="text-white text-sm font-medium tracking-widest uppercase">{galleryEntries[4].data.title}</span>
              </div>
            </>
          )}
        </div>

        <div class="md:col-span-2 relative group overflow-hidden bg-neutral-800">
          {galleryEntries[5] && getImageAsset(galleryEntries[5]) && (
            <>
              <Image
                src={getImageAsset(galleryEntries[5])()}
                alt={galleryEntries[5].data.title || 'Photography work by Alex B.'}
                class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
              />
              <div class="absolute inset-0 bg-black/20 opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-center justify-center">
                <span class="text-white text-sm font-medium tracking-widest uppercase">{galleryEntries[5].data.title}</span>
              </div>
            </>
          )}
        </div>
      </div>
    </section>
  </div>
</Layout>
