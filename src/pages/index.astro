---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import galleryConfig from '../config/gallery.json';

const allGallery = await getCollection('gallery');
console.log('GALLERY ENTRIES:', JSON.stringify(allGallery, null, 2));

const SLOTS = galleryConfig.slots;

// Simplified Slotting Logic: Only use explicit overrides from config
function matchPhotosToSlots(entries) {
  const assignments = {};

  SLOTS.forEach(slot => {
    if (slot.imageSlug) {
      const photo = entries.find(p =>
        (p.id && p.id.toLowerCase() === slot.imageSlug.toLowerCase()) ||
        (p.slug && p.slug.toLowerCase() === slot.imageSlug.toLowerCase())
      );
      if (photo) {
        assignments[slot.id] = photo;
      }
    }
  });

  return assignments;
}

const slotted = matchPhotosToSlots(allGallery);
---

<Layout title="Photography Portfolio">
  <div class="flex flex-col gap-0">
    <!-- Hero Section -->
    <section class="relative w-full overflow-hidden bg-neutral-900 aspect-video">
      {slotted.hero ? (
        <Image
          src={slotted.hero.data.image}
          alt={slotted.hero.data.title || 'Photography work by Alex B.'}
          class="h-full w-full object-cover transition-transform duration-700"
          width={SLOTS.find(s => s.id === 'hero')?.width}
          height={SLOTS.find(s => s.id === 'hero')?.height}
        />
      ) : (
        <div class="h-full w-full bg-neutral-800" />
      )}
      <div class="absolute inset-0 flex flex-col justify-end p-6 md:p-12 lg:p-20">
        <h1 class="text-6xl md:text-8xl font-bold tracking-tighter text-white mb-4">ALEX B.</h1>
        <p class="text-lg md:text-2xl text-gray-200 max-w-xl font-light">
          Capturing the stark contrast of urban environments and architectural forms.
        </p>
      </div>
    </section>

    <!-- Fluid Gallery Grid -->
    <section class="p-4 md:p-8 lg:p-12">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        {SLOTS.filter(s => s.layout === 'grid').map(slot => {
          const photo = slotted[slot.id];
          return (
            <div class={`relative group overflow-hidden bg-neutral-800 ${slot.aspectClass} ${slot.gridClass}`}>
              {photo && (
                <>
                  <Image
                    src={photo.data.image}
                    alt={photo.data.title || 'Photography work by Alex B.'}
                    class="h-full w-full object-cover transition-transform duration-500"
                    width={slot.width}
                    height={slot.height}
                  />
                  <div class="absolute inset-0 bg-black/20 opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-center justify-center">
                    <span class="text-white text-sm font-medium tracking-widest uppercase">{photo.data.title}</span>
                  </div>
                </>
              )}
            </div>
          );
        })}
      </div>
    </section>
  </div>
</Layout>
