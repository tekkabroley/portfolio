---
import Layout from "../layouts/Layout.astro";
import { getCollection } from "astro:content";
import { Image } from "astro:assets";
import galleryConfig from "../config/gallery.json";

const allGallery = await getCollection("gallery");
console.log("GALLERY ENTRIES:", JSON.stringify(allGallery, null, 2));

const SLOTS = galleryConfig.slots;

// Simplified Slotting Logic: Only use explicit overrides from config
function matchPhotosToSlots(entries) {
  const assignments = {};

  SLOTS.forEach((slot) => {
    if (slot.imageSlug) {
      const photo = entries.find(
        (p) =>
          (p.id && p.id.toLowerCase() === slot.imageSlug.toLowerCase()) ||
          (p.slug && p.slug.toLowerCase() === slot.imageSlug.toLowerCase()),
      );
      if (photo) {
        assignments[slot.id] = photo;
      }
    }
  });

  return assignments;
}

const slotted = matchPhotosToSlots(allGallery);
---

<Layout title="Photography Portfolio">
  <div class="flex flex-col gap-0">
    <!-- Fluid Gallery Grid -->
    <section class="p-4 md:p-8 lg:p-12">
      <div class="columns-1 md:columns-2 gap-2">
        {
          SLOTS.filter((s) => s.layout === "grid").map((slot) => {
            const photo = slotted[slot.id];
            return (
              <div
                class={`relative group overflow-hidden bg-neutral-100 ${slot.aspectClass} mb-2 break-inside-avoid cursor-pointer gallery-item`}
              >
                {photo && (
                  <>
                    <Image
                      src={photo.data.image}
                      alt={photo.data.title || "Photography work by Alex B."}
                      class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
                      width={slot.width}
                      height={slot.height}
                    />
                    <div class="absolute inset-0 bg-black/20 opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-center justify-center">
                      <span class="text-white text-sm font-medium tracking-widest uppercase">
                        {photo.data.title}
                      </span>
                    </div>
                  </>
                )}
              </div>
            );
          })
        }
      </div>
    </section>
  </div>

  <!-- Lightbox Modal -->
  <div
    id="lightbox"
    class="fixed top-0 bottom-0 left-40 right-20 md:left-[512px] md:right-64 z-50 hidden bg-white flex items-center justify-center p-4 md:p-12 cursor-zoom-out transition-opacity duration-300 opacity-0"
  >
    <div class="relative w-full h-full flex items-center justify-center">
      <img
        id="lightbox-image"
        src=""
        alt=""
        class="max-w-full max-h-full object-contain shadow-2xl transition-transform duration-300 scale-95"
      />
    </div>
  </div>

  <script>
    const lightbox = document.getElementById("lightbox");
    const lightboxImage = document.getElementById("lightbox-image");

    document.querySelectorAll(".gallery-item").forEach((item) => {
      item.addEventListener("click", () => {
        const img = item.querySelector("img");
        if (img && lightboxImage) {
          lightboxImage.src = img.src;
          lightboxImage.alt = img.alt;

          lightbox.classList.remove("hidden");
          // Use a timeout to trigger the opacity transition after removing 'hidden'
          setTimeout(() => {
            lightbox.classList.add("opacity-100");
            lightboxImage.classList.remove("scale-95");
            lightboxImage.classList.add("scale-100");
          }, 10);
        }
      });
    });

    lightbox.addEventListener("click", () => {
      if (lightbox && lightboxImage) {
        lightbox.classList.remove("opacity-100");
        lightboxImage.classList.remove("scale-100");
        lightboxImage.classList.add("scale-95");

        setTimeout(() => {
          lightbox.classList.add("hidden");
        }, 300);
      }
    });
  </script>
</Layout>
