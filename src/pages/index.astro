---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Photography & Dev Portfolio">
  <section class="px-6 py-20 max-w-7xl mx-auto">
    <h1 class="text-6xl font-bold tracking-tighter mb-4">ALEX B.</h1>
    <p class="text-xl text-gray-400 mb-12 max-w-2xl">
      Software Engineer & Photographer. Exploring the intersection of high-performance code and high-contrast imagery.
    </p>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      <div class="p-8 border border-white/10 bg-white/5 hover:bg-white/10 transition-colors group cursor-pointer">
        <h2 class="text-3xl font-bold mb-2 group-hover:translate-x-2 transition-transform">Software</h2>
        <p class="text-gray-400">High-performance applications and open source tools.</p>
      </div>
      <div class="p-8 border border-white/10 bg-white/5 hover:bg-white/10 transition-colors group cursor-pointer">
        <h2 class="text-3xl font-bold mb-2 group-hover:translate-x-2 transition-transform">Photography</h2>
        <p class="text-gray-400">Capturing the stark contrast of urban environments.</p>
      </div>
    </div>
  </section>
</Layout>
