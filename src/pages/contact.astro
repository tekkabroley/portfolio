---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Contact">
  <div class="flex flex-col gap-0 pt-10 px-4 md:px-0">
    <section class="max-w-xl">
      <h1 class="text-4xl font-baskerville mb-12">Get in Touch</h1>

      <form action="/contact" method="POST" class="flex flex-col gap-8">
        <div class="flex flex-col gap-2">
          <label for="name" class="text-xs uppercase tracking-widest text-neutral-500 font-sans">Name</label>
          <input
            type="text"
            id="name"
            name="name"
            required
            class="w-full py-2 border-b border-neutral-200 focus:border-black outline-none transition-colors duration-300 bg-transparent font-sans"
            placeholder="Your Name"
          />
        </div>

        <div class="flex flex-col gap-2">
          <label for="email" class="text-xs uppercase tracking-widest text-neutral-500 font-sans">Email</label>
          <input
            type="email"
            id="email"
            name="email"
            required
            class="w-full py-2 border-b border-neutral-200 focus:border-black outline-none transition-colors duration-300 bg-transparent font-sans"
            placeholder="email@example.com"
          />
        </div>

        <div class="flex flex-col gap-2">
          <label for="message" class="text-xs uppercase tracking-widest text-neutral-500 font-sans">Message</label>
          <textarea
            id="message"
            name="message"
            required
            rows="4"
            class="w-full py-2 border-b border-neutral-200 focus:border-black outline-none transition-colors duration-300 bg-transparent font-sans resize-none"
            placeholder="Tell me about your project..."
          ></textarea>
        </div>

        <button
          type="submit"
          class="w-fit px-8 py-3 bg-black text-white text-xs uppercase tracking-widest hover:bg-neutral-800 transition-colors duration-300"
        >
          Send Message
        </button>
      </form>
    </section>
  </div>
</Layout>
