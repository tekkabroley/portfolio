---
import Layout from "../layouts/Layout.astro";

// Get error param if it exists (for incorrect pin)
const error = Astro.url.searchParams.get('error');
---

<Layout title="Family Access">
  <div class="flex flex-col items-center justify-center min-h-[70vh] px-4">
    <div class="w-full max-w-md">
      <h1 class="text-5xl font-baskerville tracking-tighter mb-6 text-center">Private Area</h1>
      <p class="text-neutral-500 text-center mb-12">
        This section contains personal family photos. Please enter the access code to continue.
      </p>

      {error === '1' && (
        <div class="bg-red-50 text-red-600 text-sm p-4 mb-6 text-center border border-red-100">
          Incorrect PIN. Please try again.
        </div>
      )}
      
      {error === 'config' && (
        <div class="bg-red-50 text-red-600 text-sm p-4 mb-6 text-center border border-red-100">
          System error: Access code not configured on the server.
        </div>
      )}

      <form action="/api/verify-pin" method="POST" class="flex flex-col gap-6">
        <div class="flex flex-col gap-2 text-center">
          <input
            type="password"
            id="pin"
            name="pin"
            inputmode="numeric"
            pattern="[0-9]*"
            required
            class="w-full text-center text-3xl tracking-[1em] py-4 border-b-2 border-neutral-200 focus:border-black outline-none transition-colors duration-300 bg-transparent font-sans"
            placeholder="****"
            autofocus
          />
        </div>

        <button
          type="submit"
          class="w-full px-8 py-4 mt-4 bg-black text-white text-xs uppercase tracking-widest hover:bg-neutral-800 transition-colors duration-300"
        >
          Unlock
        </button>
      </form>
    </div>
  </div>
</Layout>
