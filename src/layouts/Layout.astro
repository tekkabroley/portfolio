---
import "../styles/global.css";
import { Image } from "astro:assets";
import logo from "../assets/logo.png";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{Astro.props.title || "Portfolio"}</title>
  </head>
  <body
    class="bg-white text-neutral-900 selection:bg-neutral-900 selection:text-white antialiased"
  >
    <div class="flex min-h-screen">
      <aside
        class="w-32 md:w-[410px] bg-white text-neutral-500 flex flex-col p-6 shrink-0 sticky top-0 h-screen"
      >
        <div class="mb-12">
          <a href="/" class="block">
            <Image src={logo} alt="Alex B. Logo" class="w-full h-auto" />
          </a>
        </div>
        <nav
          class="flex flex-col gap-10 text-4xl font-bold tracking-tighter text-black font-baskerville"
        >
          <a
            href="/collections"
            class="transition-colors hover:text-neutral-900">Collections</a
          >
          <a href="/about" class="transition-colors hover:text-neutral-900"
            >About</a
          >
          <a href="/contact" class="transition-colors hover:text-neutral-900"
            >Contact</a
          >
          <a href="/gear" class="transition-colors hover:text-neutral-900"
            >My Gear</a
          >
          <!-- <a href="/family" class="transition-colors hover:text-neutral-900">Family</a> -->
        </nav>
        <div class="mt-8">
          <a
            href="https://instagram.com/your-handle"
            target="_blank"
            rel="noopener noreferrer"
            class="text-black hover:text-neutral-900 transition-colors inline-block"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="24"
              height="24"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <rect width="20" height="20" x="2" y="2" rx="5" ry="5"></rect>
              <path d="M16 11.37A4 4 0 1 1 12.01 8 4 4 0 0 1 16 11.37z"></path>
              <line x1="17.8" x2="17.8" y1="2" y2="4"></line>
              <line x1="16.2" x2="16.2" y1="2" y2="4"></line>
              <line x1="7" x2="7" y1="2" y2="4"></line>
              <line x1="5.4" x2="5.4" y1="2" y2="4"></line>
            </svg>
          </a>
        </div>
      </aside>
      <div class="flex-1 flex flex-col overflow-hidden">
        <main class="min-h-screen">
          <slot />
        </main>
      </div>
      <aside
        class="w-16 md:w-[205px] bg-white text-neutral-500 flex flex-col p-6 shrink-0 sticky top-0 h-screen"
      >
        <!-- Right Sidebar Content -->
      </aside>
    </div>
  </body>
</html>
